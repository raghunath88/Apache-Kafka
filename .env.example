# Copy to .env and fill in values — never commit .env to git

KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=dwp-producer
KAFKA_TOPIC=dwp.orders
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

